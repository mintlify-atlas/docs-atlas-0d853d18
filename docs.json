  "$schema": "https://mintlify.com/docs.json",
  "name": "ElectroHome",
  "theme": "almond",
  "colors": {
    "primary": "#1E4D8C",
    "light": "#3A7BD5",
    "dark": "#0F2A52"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/alan1130co/ecommerce-electrohome"
    }
  },
  "footer": {
