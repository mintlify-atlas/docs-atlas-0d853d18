  "keyFeatures": [
    "Product catalog with electronics and home appliance listings",
    "Shopping cart and checkout flow",
    "Wompi payment gateway integration for Colombian market",
    "Google OAuth social authentication via django-allauth",
    "Cloudinary-based media storage for product images",
    "Django admin panel for store management",
    "WhiteNoise static file serving",
    "Production deployment on Render with PostgreSQL via dj-database-url"
  ],
  "publicApiSurface": [
    "GET /admin/ - Django admin panel",
    "GET /accounts/ - Authentication endpoints (allauth)",
    "GET /products/ - Product listing and detail views",
    "POST /cart/ - Shopping cart management",
    "POST /checkout/ - Order placement and payment",
    "GET /orders/ - Order history",
    "POST /payments/wompi/ - Wompi payment webhook"
